# Copier vers .env (ne jamais commiter .env)
# Base PostgreSQL (Neon, Supabase, Railway, Vercel Postgres, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth — en prod : URL exacte du site (ex. https://planning-pharmacie.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# Secret : openssl rand -base64 32
NEXTAUTH_SECRET="remplacer-par-une-longue-chaine-aleatoire"
